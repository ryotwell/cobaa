{
  "name": "railway-gateway",
  "version": "1.0.0",
  "description": "Proxy Gateway dengan WebSocket & UDP native support untuk Railway",
  "main": "dist/index.js",
  "packageManager": "bun@1.1.10",
  "scripts": {
    "start": "bun run dist/index.js",
    "dev": "bun --watch src/index.ts",
    "build": "bun build src/index.ts --outdir ./dist --target bun",
    "test": "echo \"No tests specified\" && exit 0",
    "clean": "rm -rf node_modules dist bun.lockb"
  },
  "dependencies": {
    "dotenv": "17.4.2",
    "ws": "^8.14.2"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "keywords": [
    "proxy",
    "gateway",
    "websocket",
    "udp",
    "trojan",
    "vmess",
    "shadowsocks",
    "railway"
  ],
  "author": "Kuncung",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "25.9.1",
    "@types/ws": "8.18.1",
    "tsx": "4.22.4",
    "typescript": "6.0.3"
  }
}