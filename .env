# Railway Gateway Environment Variables
PORT=3000
NODE_ENV=production

# Proxy Configuration
# PRX_BANK_URL is no longer needed (Running in Standalone Mode)
REVERSE_PRX_TARGET=example.com

# Security (optional)
ENABLE_RATE_LIMITING=false
ALLOWED_ORIGINS=*

# UDP Configuration
UDP_TIMEOUT=30000
MAX_UDP_CONNECTIONS=100

# Logging
LOG_LEVEL=info
